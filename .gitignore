# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv-pipeline/
.pytest_cache/
.ruff_cache/

# --- Node / web ---
node_modules/
web/dist/
web/.vite/
# generated by web/copy-data.mjs (canonical copies live in data/artifacts + manifests + qlab/)
web/public/data/
web/public/manifests/
web/public/pyodide/
*.tsbuildinfo

# --- Secrets / env (this repo is PUBLIC — never commit these) ---
# Real quantum-cloud tokens (IBM Quantum / AWS / Azure) live ONLY in the CAOS_MANAGE vault and are
# used locally by the precompute pipeline. The public static site ships NO secrets.
.env
.env.*
!.env.example

# --- Raw / heavy data (commit only compact rendered artifacts under data/artifacts/) ---
data/raw/
# raw statevector / large NumPy dumps — the committed artifacts are compact JSON traces only
*.npy
*.npz
*.h5
*.parquet

# --- OS ---
.DS_Store
Thumbs.db

# review/wip artifacts belong in CAOS_MANAGE, never this public repo
/wip/
